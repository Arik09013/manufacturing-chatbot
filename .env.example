# ── LLM synthesis backend ──────────────────────────────────────────────
# Which backend narrates the pipeline output: anthropic | groq | ollama
# (If 'anthropic' is selected but ANTHROPIC_API_KEY is missing while GROQ_API_KEY
#  is set, it auto-falls back to Groq so the demo still runs.)
SYNTHESIZER_BACKEND=anthropic

# ── Anthropic (Claude) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Model used to NARRATE deterministic results (anomaly / param / welding knowledge).
# Cheap is fine here — it only phrases pre-computed output.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Model for GENERAL manufacturing questions (CNC, moulding, casting, additive,
# lean/OEE…). Here the model IS the knowledge source, so use a capable one.
ANTHROPIC_GENERAL_MODEL=claude-opus-4-8

# ── Groq (fast hosted Llama) ───────────────────────────────────────────
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama (local, offline) ────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3.2
